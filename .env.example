# Backend API URL
VITE_API_URL=http://localhost:8080

# Telegram Bot URL — used for referral links (e.g. https://t.me/YourBotName)
VITE_BOT_URL=

# Bot token for HMAC-signed mock initData in dev mode.
# Copy from @BotFather. Used ONLY in browser dev — never shipped to production.
# Add to .env.local (gitignored):
VITE_DEV_BOT_TOKEN=

# TON Connect manifest URL.
# Must be publicly accessible — wallet apps fetch it to verify the dApp.
# In production: set to your Mini App's URL + /tonconnect-manifest.json
# In dev: auto-detected as window.location.origin/tonconnect-manifest.json
VITE_TONCONNECT_MANIFEST_URL=

# AdSgram rewarded-video Block ID for the "watch ad → get 50 gold" task.
# Empty value disables the task on the Tasks screen.
VITE_ADSGRAM_REWARD_GOLD_BLOCK_ID=36570

# Kill switch for the mobile-only gate. Set to `true` to let desktop users
# through MobileGuard (used for conversion experiments). Anything else keeps
# the guard on — admins still bypass via VITE_ADMIN_IDS.
VITE_ENABLED_DESKTOP=
